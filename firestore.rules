rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function isSignedIn() {
      return request.auth != null;
    }
    
    // --- Lead Validation ---
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.phone is string && data.phone.size() >= 5 && data.phone.size() <= 30 &&
             data.createdAt == request.time;
    }

    // --- Collections ---
    match /leads/{leadId} {
      allow create: if isValidId(leadId) && isValidLead(incoming());
      // No read, update, or delete for public or even authenticated users (except maybe admins in the console)
    }
  }
}
